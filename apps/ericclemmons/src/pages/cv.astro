---
import Container from '@/components/Container.astro'
import Layout from '@/layouts/Spotlight.astro'
import { yearRange } from '@/lib/formatDate'
import { getResume } from '@/lib/getResume'

const resume = await getResume()
const { basics, work, projects, skills, education, references } = resume
---

<Layout title="CV" description={`${basics.name} — ${basics.label}`}>
  <Container className="mt-16 sm:mt-32">
    <div class="mx-auto max-w-2xl font-satoshi">

      <!-- Header -->
      <header class="mb-12">
        <h1 class="font-lora text-4xl tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl text-balance">
          {basics.name}
        </h1>
        <p class="mt-2 text-lg text-zinc-600 dark:text-zinc-400">
          {basics.label}
        </p>
        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1 font-ibm-plex text-xs text-zinc-400 dark:text-zinc-500">
          <span>{basics.location.city}, {basics.location.region}</span>
          {basics.profiles.map((p) => (
            <a href={p.url} class="transition-colors hover:text-amber-700 dark:hover:text-amber-400">{p.url.replace(/^https?:\/\//, '')}</a>
          ))}
        </div>
        <p class="mt-6 text-sm text-zinc-600 dark:text-zinc-400 text-pretty">
          {basics.summary}
        </p>
      </header>

      <!-- Experience -->
      <section class="mb-16">
        <h2 class="mb-8 font-lora text-xl text-zinc-900 dark:text-zinc-100">Experience</h2>
        <div class="space-y-10">
          {work.map((role) => (
            <div>
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="text-base font-medium text-zinc-900 dark:text-zinc-100">
                  {role.position}
                  <span class="text-zinc-400 dark:text-zinc-500"> · </span>
                  {role.name}
                </h3>
                <span class="shrink-0 font-ibm-plex text-xs tabular-nums text-zinc-400 dark:text-zinc-600">
                  {yearRange(role.startDate, role.endDate)}
                </span>
              </div>
              <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 text-pretty">{role.summary}</p>
              {role.highlights?.length > 0 && (
                <ul class="mt-3 list-disc space-y-1.5 pl-4" role="list">
                  {role.highlights.map((h) => (
                    <li class="text-sm text-zinc-600 marker:text-amber-400/60 dark:text-zinc-400 dark:marker:text-amber-600/40">
                      {h}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Projects -->
      {projects?.length > 0 && (
        <section class="mb-16">
          <h2 class="mb-8 font-lora text-xl text-zinc-900 dark:text-zinc-100">Projects</h2>
          <div class="space-y-5">
            {projects.map((proj) => (
              <a href={proj.url} class="group block">
                <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">
                  {proj.name}
                </h3>
                <p class="mt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{proj.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Skills -->
      {skills?.length > 0 && (
        <section class="mb-16">
          <h2 class="mb-8 font-lora text-xl text-zinc-900 dark:text-zinc-100">Skills</h2>
          <div class="space-y-4">
            {skills.map((group) => (
              <div>
                <h3 class="text-sm font-medium text-zinc-700 dark:text-zinc-300">{group.name}</h3>
                <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{group.keywords.join(' · ')}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Education -->
      {education?.length > 0 && (
        <section class="mb-16">
          <h2 class="mb-8 font-lora text-xl text-zinc-900 dark:text-zinc-100">Education</h2>
          {education.map((edu) => (
            <div class="flex items-baseline justify-between gap-4">
              <div>
                <h3 class="text-base font-medium text-zinc-900 dark:text-zinc-100">{edu.institution}</h3>
                <p class="mt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{edu.studyType}, {edu.area}</p>
              </div>
              <span class="shrink-0 font-ibm-plex text-xs tabular-nums text-zinc-400 dark:text-zinc-600">
                {new Date(edu.endDate).getFullYear()}
              </span>
            </div>
          ))}
        </section>
      )}

      <!-- Testimonials -->
      {references?.length > 0 && (
        <section class="mb-16">
          <h2 class="mb-8 font-lora text-xl text-zinc-900 dark:text-zinc-100">What Others Say</h2>
          <div class="space-y-8">
            {references.map((t) => (
              <blockquote class="border-l-2 border-amber-300/60 pl-5 dark:border-amber-700/30">
                <p class="text-sm text-zinc-600 dark:text-zinc-400 text-pretty">"{t.reference}"</p>
                <footer class="mt-2 font-ibm-plex text-xs text-zinc-400 dark:text-zinc-500">— {t.name}</footer>
              </blockquote>
            ))}
          </div>
        </section>
      )}

      <!-- JSON Resume link -->
      <div class="border-t border-zinc-100 pt-8 dark:border-zinc-800/80">
        <p class="text-sm text-zinc-400 dark:text-zinc-500">
          This CV is also available as <a href="https://registry.jsonresume.org/ericclemmons" class="text-amber-700 transition-colors hover:text-amber-800 dark:text-amber-400 dark:hover:text-amber-300">JSON Resume</a>.
        </p>
      </div>

    </div>
  </Container>
</Layout>
