---
import Layout from '@/layouts/Spotlight.astro'
import { formatDate } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'

const posts = await getPosts()
---

<Layout
  title="Writing"
  description="Writing on software engineering, management, and working remotely."
>
  <div class="px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-2xl lg:max-w-3xl">
      <header class="mt-16 sm:mt-24">
        <h1 class="font-serif text-4xl sm:text-5xl font-normal tracking-tight text-stone-900 dark:text-stone-100">
          Writing
        </h1>
        <p class="mt-4 text-base text-stone-500 dark:text-stone-400">
          Thoughts, discoveries, and technical writeups.
        </p>
      </header>

      <div class="mt-16 sm:mt-20">
        {
          posts.map((post) => (
            <article class="border-b border-stone-200 dark:border-stone-800 py-8 first:pt-0">
              <a href={`/blog/${post.slug}`} class="group block">
                <h2 class="font-serif text-xl sm:text-2xl font-normal text-stone-900 dark:text-stone-100 group-hover:text-stone-600 dark:group-hover:text-stone-300 transition">
                  {post.data.title}
                </h2>
                {post.data.summary && (
                  <p class="mt-2 text-base text-stone-500 dark:text-stone-400 line-clamp-2">
                    {post.data.summary}
                  </p>
                )}
                <time
                  datetime={formatDate(post.data.date)}
                  class="mt-2 block text-sm text-stone-400 dark:text-stone-500"
                >
                  {formatDate(post.data.date)}
                </time>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
