---
import Container from '@/components/Container.astro'
import PostArchive from '@/components/PostArchive.astro'
import Layout from '@/layouts/Spotlight.astro'
import { groupByYear } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'

const posts = await getPosts()
const { years } = groupByYear(posts)
---

<Layout
  title="Blog"
  description="Writing on software engineering, management, and working remotely."
>
  <Container className="mt-16 sm:mt-32">
    <div class="mx-auto max-w-2xl font-satoshi">
      <header class="mb-16">
        <h1
          class="font-display text-4xl tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl text-balance"
        >
          Archive
        </h1>
        <p class="mt-2 text-sm tabular-nums text-zinc-400 dark:text-zinc-500">
          {posts.length} posts since {years[years.length - 1]}
        </p>
      </header>

      <PostArchive posts={posts} />
    </div>
  </Container>
</Layout>
