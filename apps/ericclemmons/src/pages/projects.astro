---
import ArrowLink from '@/components/ArrowLink.astro'
import Layout from '@/layouts/Simple.astro'

const projects = [
  {
    name: 'AWS Amplify',
    description:
      'Lead for Amplify UI – accessible cloud-connected, cross-framework components.',
    href: 'https://ui.docs.amplify.aws/',
    label: 'ui.docs.amplify.aws',
  },
  {
    name: 'codelift',
    description: 'Visual Development for Tailwind CSS',
    href: 'https://codelift.app/',
    label: 'codelift.app',
  },
  {
    name: 'Click-to-Component',
    description:
      'Option+Click React components in your browser to instantly open the source in VS Code',
    href: 'https://github.com/ericclemmons/click-to-component',
    label: 'github.com',
  },
  {
    name: 'node-recorder',
    description:
      'Simple recording & replaying of HTTP requests for predictable development & testing.',
    href: 'https://github.com/ericclemmons/node-recorder',
    label: 'github.com',
  },
  {
    name: 'polydev',
    description:
      'Faster, route-centric development for Node.js apps with built-in Hot Module Replacement.',
    href: 'https://github.com/ericclemmons/polydev',
    label: 'github.com',
  },
  {
    name: 'mdx-site',
    description: 'Static site generator powered by TypeScript, MDX, & React.',
    href: 'https://github.com/ericclemmons/mdx-site',
    label: 'github.com',
  },
]
---

<Layout
  title="Projects"
  description="I open-source generic solutions for the larger community to benefit from."
>
  <Fragment slot="title">A few projects I'm proud of.</Fragment>

  <Fragment slot="intro">
    I open-source generic solutions for the larger community to benefit from. I
    also share my prototypes that improve DX in the hopes others can benefit.
  </Fragment>

  <div class="space-y-10">
    {
      projects.map((project) => (
        <a href={project.href} class="group block">
          <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">
            {project.name}
          </h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
            {project.description}
          </p>
          <span class="mt-1.5 inline-flex items-center gap-1.5 font-ibm-plex text-xs text-zinc-400 transition-colors group-hover:text-amber-700 dark:text-zinc-500 dark:group-hover:text-amber-400">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
            {project.label}
          </span>
        </a>
      ))
    }
    <ArrowLink href="https://github.com/ericclemmons?tab=repositories&sort=stargazers">
      View all repositories
    </ArrowLink>
  </div>
</Layout>
