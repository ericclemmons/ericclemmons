---
import {
  GitHubIcon,
  LinkedInIcon,
  MailIcon,
  TwitterIcon,
} from '@/components/Icons'
import Layout from '@/layouts/Spotlight.astro'
import { Picture } from 'astro:assets'
---

<Layout
  title="About"
  description="I'm Eric Clemmons. I live in Austin, TX, where I create solutions that positively impact teams & users."
>
  <div class="px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-2xl lg:max-w-3xl">
      <div class="mt-16 sm:mt-24">
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-normal tracking-tight text-stone-900 dark:text-stone-100">
          Eric Clemmons
        </h1>

        <div class="mt-8 flex flex-col sm:flex-row gap-12">
          <div class="shrink-0">
            <Picture
              alt="Eric Clemmons"
              class="bg-stone-100 dark:bg-stone-800 h-48 w-48 rounded-2xl object-cover grayscale"
              sizes="192px"
              src={import('@/images/portrait.jpg')}
              widths={[192, 384]}
            />
          </div>
          <div class="space-y-6 text-base text-stone-600 dark:text-stone-400 leading-relaxed">
            <p>
              I'm an engineering leader specializing in autonomous, outcome-driven
              remote teams with over 15 years of experience as an open-source
              JavaScript/Node.js developer focused on UX/DX.
            </p>

            <p>
              My industry experience ranges from organic SEO lead-generation in
              online education (HigherEducation.com), to cross-team mobile
              experiences (Starbucks), to leading new open-source UI teams at AWS
              Amplify & Stripe.
            </p>

            <p>
              In my free time, I learn new recipes to cook for my family, play
              music on drums & guitar, and sherpa clanmates in Destiny 2.
            </p>
          </div>
        </div>

        <div class="mt-12">
          <p class="text-xs font-medium uppercase tracking-widest text-stone-400 dark:text-stone-500">
            Lives in Austin, TX, and:
          </p>
          <div class="mt-4 flex gap-5">
            <a href="https://twitter.com/ericclemmons" class="group" aria-label="Follow on Twitter">
              <TwitterIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
            </a>
            <a href="https://github.com/ericclemmons" class="group" aria-label="Follow on GitHub">
              <GitHubIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
            </a>
            <a href="https://www.linkedin.com/in/ericclemmons" class="group" aria-label="Follow on LinkedIn">
              <LinkedInIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
            </a>
            <a href="mailto:eric@smarterspam.com" class="group" aria-label="Email">
              <MailIcon className="h-5 w-5 fill-stone-400 stroke-stone-400 transition group-hover:fill-stone-600 group-hover:stroke-stone-600 dark:fill-stone-500 dark:stroke-stone-500 dark:group-hover:fill-stone-300 dark:group-hover:stroke-stone-300" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
