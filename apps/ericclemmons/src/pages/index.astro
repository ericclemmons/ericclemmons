---
import ArrowLink from '@/components/ArrowLink.astro'
import Container from '@/components/Container.astro'
import PostArchive from '@/components/PostArchive.astro'
import Section from '@/components/Section.astro'
import { GitHubIcon, LinkedInIcon, XIcon } from '@/components/Icons'
import Layout from '@/layouts/Spotlight.astro'
import { formatDate, shortDate, yearRange } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'
import { getResume } from '@/lib/getResume'
import profilePhoto from '@/images/profile.jpg'

const posts = await getPosts()
const resume = await getResume()

const allRoles = resume.work
const osProjects = resume.projects?.slice(0, 2) ?? []

const latestDate = posts[0]?.data.date ?? new Date()
const oneYearAgo = new Date(latestDate)
oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1)

const featuredPosts = posts.filter((p) => p.data.date >= oneYearAgo)
const archivePosts = posts.filter((p) => p.data.date < oneYearAgo)
---

<Layout>
  <Container className="mt-16 sm:mt-24">
    <div class="font-satoshi">

      <!-- Hero -->
      <div class="mb-20" data-enter style="--enter-delay: 0ms">
        <h1 class="font-display text-5xl tracking-tight text-zinc-900 dark:text-zinc-100 text-balance">
          {resume.basics.name}
        </h1>
        <div class="mt-8 grid max-w-3xl grid-cols-1 items-start gap-y-6 md:grid-cols-[140px_1fr]">
          <img
            src={profilePhoto.src}
            alt="Eric Clemmons"
            width={140}
            height={140}
            class="w-24 aspect-square rounded-2xl object-cover shadow-lg ring-1 ring-zinc-900/5 md:w-[112px] dark:ring-zinc-100/10 dark:shadow-zinc-950/40"
          />
          <div>
            <div class="space-y-4 text-base text-zinc-600 dark:text-zinc-400">
              <p class="text-pretty">
                I lead engineering teams and build open-source tools for the web.
                17 years shipping across the stack — from startups to AWS, Stripe,
                and Cloudflare. Right now I'm deep in AI-native development and
                what comes next for developer tooling.
              </p>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">
                When I'm not coding: cooking for my family, drums & guitar, Destiny 2.
              </p>
            </div>

            <div class="mt-6 flex gap-5">
              <a href="https://x.com/ericclemmons" aria-label="Follow on X" class="fill-zinc-400 transition-all duration-200 hover:fill-amber-700 hover:scale-110 dark:fill-zinc-500 dark:hover:fill-amber-400"><XIcon className="size-5" /></a>
              <a href="https://github.com/ericclemmons" aria-label="Follow on GitHub" class="fill-zinc-400 transition-all duration-200 hover:fill-amber-700 hover:scale-110 dark:fill-zinc-500 dark:hover:fill-amber-400"><GitHubIcon className="size-5" /></a>
              <a href="https://www.linkedin.com/in/ericclemmons" aria-label="Follow on LinkedIn" class="fill-zinc-400 transition-all duration-200 hover:fill-amber-700 hover:scale-110 dark:fill-zinc-500 dark:hover:fill-amber-400"><LinkedInIcon className="size-5" /></a>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-20">
        <!-- Experience -->
        <div data-enter style="--enter-delay: 100ms">
          <Section title="Experience">
            <div class="space-y-1">
              {allRoles.map((role) => (
                <div class="group/item -mx-3 rounded-lg px-3 py-3 transition-all duration-200 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
                  <div class="grid grid-cols-[1fr_auto] gap-x-4">
                    <h3 class="text-base font-medium text-zinc-900 transition-transform duration-200 group-hover/item:translate-x-0.5 dark:text-zinc-100">
                      {role.position} <span class="text-zinc-400 dark:text-zinc-500">at</span> {role.name}
                    </h3>
                    <span class="self-baseline font-code text-xs tabular-nums text-zinc-400 dark:text-zinc-600">{yearRange(role.startDate, role.endDate)}</span>
                    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 text-balance">{role.summary}</p>
                  </div>
                </div>
              ))}
            </div>
            <ArrowLink href="/cv" class="mt-6">Full CV</ArrowLink>
          </Section>
        </div>

        <!-- Open Source -->
        <div data-enter style="--enter-delay: 200ms">
          <Section title="Open Source">
            <div class="space-y-1">
              {osProjects.map((proj) => (
                <a href={proj.url} class="group -mx-3 block rounded-lg px-3 py-3 transition-all duration-200 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
                  <h3 class="text-base font-medium text-zinc-900 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">{proj.name}</h3>
                  <p class="mt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{proj.description}</p>
                </a>
              ))}
            </div>
          </Section>
        </div>

        <!-- Recent Writing -->
        <div data-enter style="--enter-delay: 300ms">
          <Section title="Recent Writing">
            <div class="space-y-2">
              {featuredPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group -mx-3 block rounded-lg px-3 py-3 transition-all duration-200 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
                  <time datetime={formatDate(post.data.date)} class="font-code text-xs tabular-nums text-zinc-400 dark:text-zinc-600">{shortDate(post.data.date)}</time>
                  <h3 class="mt-1.5 font-display text-xl text-zinc-900 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">{post.data.title}</h3>
                  {post.data.summary && <p class="mt-1.5 text-sm text-zinc-500 dark:text-zinc-400 text-pretty">{post.data.summary}</p>}
                </a>
              ))}
            </div>
          </Section>
        </div>

        <!-- Archive -->
        {archivePosts.length > 0 && (
          <div data-enter style="--enter-delay: 400ms">
            <Section title="Archive">
              <PostArchive posts={archivePosts} />
            </Section>
          </div>
        )}
      </div>

    </div>
  </Container>
</Layout>
