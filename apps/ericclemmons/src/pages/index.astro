---
import { GitHubIcon, LinkedInIcon, MailIcon, TwitterIcon } from '@/components/Icons'
import Layout from '@/layouts/Spotlight.astro'
import { formatDate } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'
import { Picture } from 'astro:assets'

const posts = (await getPosts()).slice(0, 4)
---

<Layout>
  <div class="px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-2xl lg:max-w-3xl">
      <!-- Hero -->
      <div class="mt-16 sm:mt-24 text-center">
        <div class="mb-8 flex justify-center">
          <Picture
            alt="Eric Clemmons"
            class="h-40 w-40 rounded-full bg-stone-100 object-cover dark:bg-stone-800 grayscale"
            sizes="160px"
            src={import('@/images/portrait.jpg')}
            widths={[160, 320]}
          />
        </div>
        <h1 class="font-serif text-4xl sm:text-5xl font-normal tracking-tight text-stone-900 dark:text-stone-100">
          Eric Clemmons
        </h1>
        <p class="mt-6 text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-xl mx-auto">
          Engineering leader and open-source developer specializing in
          user-centered, remote teams. Based in Austin, TX.
        </p>
        <div class="mt-8 flex justify-center gap-6">
          <a href="https://twitter.com/ericclemmons" class="group" aria-label="Follow on Twitter">
            <TwitterIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
          </a>
          <a href="https://github.com/ericclemmons" class="group" aria-label="Follow on GitHub">
            <GitHubIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
          </a>
          <a href="https://www.linkedin.com/in/ericclemmons" class="group" aria-label="Follow on LinkedIn">
            <LinkedInIcon className="h-5 w-5 fill-stone-400 transition group-hover:fill-stone-600 dark:fill-stone-500 dark:group-hover:fill-stone-300" />
          </a>
          <a href="mailto:eric@smarterspam.com" class="group" aria-label="Email">
            <MailIcon className="h-5 w-5 fill-stone-400 stroke-stone-400 transition group-hover:fill-stone-600 group-hover:stroke-stone-600 dark:fill-stone-500 dark:stroke-stone-500 dark:group-hover:fill-stone-300 dark:group-hover:stroke-stone-300" />
          </a>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-stone-200 dark:border-stone-800 mt-16 sm:mt-20"></div>

      <!-- Recent posts -->
      <div class="mt-16 sm:mt-20">
        <p class="text-xs font-medium uppercase tracking-widest text-stone-400 dark:text-stone-500">
          Recent
        </p>
        <div class="mt-6">
          {posts.map((post) => (
            <article class="border-b border-stone-200 dark:border-stone-800 py-6 first:pt-0">
              <a href={`/blog/${post.slug}`} class="group block">
                <h2 class="font-serif text-xl sm:text-2xl font-normal text-stone-900 dark:text-stone-100 group-hover:text-stone-600 dark:group-hover:text-stone-300 transition">
                  {post.data.title}
                </h2>
                <time
                  datetime={formatDate(post.data.date)}
                  class="mt-2 block text-sm text-stone-400 dark:text-stone-500"
                >
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })}
                </time>
              </a>
            </article>
          ))}
        </div>
        <div class="mt-8">
          <a href="/blog" class="text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-200 transition">
            All writing &rarr;
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
