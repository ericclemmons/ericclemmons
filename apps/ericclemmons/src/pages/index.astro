---
import ArrowLink from '@/components/ArrowLink.astro'
import Container from '@/components/Container.astro'
import PostArchive from '@/components/PostArchive.astro'
import Section from '@/components/Section.astro'
import { GitHubIcon, LinkedInIcon, XIcon } from '@/components/Icons'
import Layout from '@/layouts/Spotlight.astro'
import { formatDate, shortDate, yearRange } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'
import { getResume } from '@/lib/getResume'

const posts = await getPosts()
const resume = await getResume()

const allRoles = resume.work
const osProjects = resume.projects?.slice(0, 2) ?? []

const latestDate = posts[0]?.data.date ?? new Date()
const oneYearAgo = new Date(latestDate)
oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1)

const featuredPosts = posts.filter((p) => p.data.date >= oneYearAgo)
const archivePosts = posts.filter((p) => p.data.date < oneYearAgo)
---

<Layout>
  <Container className="mt-16 sm:mt-24">
    <div class="font-satoshi">

      <!-- Hero -->
      <div class="mx-auto mb-20 max-w-2xl">
        <h1 class="font-lora text-5xl tracking-tight text-zinc-900 dark:text-zinc-100 text-balance">
          {resume.basics.name}
        </h1>
        <div class="mt-6 space-y-4 text-base text-zinc-600 dark:text-zinc-400">
          <p class="text-pretty">
            I lead engineering teams and build open-source tools for the web.
            17 years shipping across the stack — from startups to AWS, Stripe,
            and Cloudflare. Right now I'm deep in AI-native development and
            what comes next for developer tooling.
          </p>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">
            When I'm not coding: cooking for my family, drums & guitar, Destiny 2.
          </p>
        </div>

        <div class="mt-6 flex gap-5">
          <a href="https://x.com/ericclemmons" aria-label="Follow on X" class="fill-zinc-400 transition-colors hover:fill-amber-700 dark:fill-zinc-500 dark:hover:fill-amber-400"><XIcon className="size-5" /></a>
          <a href="https://github.com/ericclemmons" aria-label="Follow on GitHub" class="fill-zinc-400 transition-colors hover:fill-amber-700 dark:fill-zinc-500 dark:hover:fill-amber-400"><GitHubIcon className="size-5" /></a>
          <a href="https://www.linkedin.com/in/ericclemmons" aria-label="Follow on LinkedIn" class="fill-zinc-400 transition-colors hover:fill-amber-700 dark:fill-zinc-500 dark:hover:fill-amber-400"><LinkedInIcon className="size-5" /></a>
        </div>
      </div>

      <div class="space-y-20">
        <!-- Experience -->
        <Section title="Experience">
          <div class="space-y-6">
            {allRoles.map((role) => (
              <div class="grid grid-cols-[1fr_auto] gap-x-4">
                <h3 class="text-base font-medium text-zinc-900 dark:text-zinc-100">
                  {role.position} <span class="text-zinc-400 dark:text-zinc-500">at</span> {role.name}
                </h3>
                <span class="self-baseline font-ibm-plex text-xs tabular-nums text-zinc-400 dark:text-zinc-600">{yearRange(role.startDate, role.endDate)}</span>
                <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 text-balance">{role.summary}</p>
              </div>
            ))}
          </div>
          <ArrowLink href="/cv" class="mt-6">Full CV</ArrowLink>
        </Section>

        <!-- Open Source -->
        <Section title="Open Source">
          <div class="space-y-4">
            {osProjects.map((proj) => (
              <a href={proj.url} class="group block">
                <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">{proj.name}</h3>
                <p class="mt-0.5 text-sm text-zinc-500 dark:text-zinc-400">{proj.description}</p>
              </a>
            ))}
          </div>
        </Section>

        <!-- Recent Writing -->
        <Section title="Recent Writing">
          <div class="space-y-10">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class="group block">
                <time datetime={formatDate(post.data.date)} class="font-ibm-plex text-xs tabular-nums text-zinc-400 dark:text-zinc-600">{shortDate(post.data.date)}</time>
                <h3 class="mt-1.5 font-lora text-xl text-zinc-900 transition-colors group-hover:text-amber-700 dark:text-zinc-100 dark:group-hover:text-amber-400">{post.data.title}</h3>
                {post.data.summary && <p class="mt-1.5 text-sm text-zinc-500 dark:text-zinc-400 text-pretty">{post.data.summary}</p>}
              </a>
            ))}
          </div>
        </Section>

        <!-- Archive -->
        {archivePosts.length > 0 && (
          <Section title="Archive">
            <PostArchive posts={archivePosts} />
          </Section>
        )}
      </div>

    </div>
  </Container>
</Layout>
