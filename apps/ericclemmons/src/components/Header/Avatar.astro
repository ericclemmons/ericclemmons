---
import avatar from '@/images/avatar.jpg'

const { props } = Astro
const { className, large = false } = props
---

<img
  src={avatar.src}
  alt="Eric Clemmons"
  class:list={[
    className,
    'rounded-full bg-stone-100 object-cover dark:bg-stone-800',
    large ? 'h-16 w-16' : 'h-9 w-9',
  ]}
/>
