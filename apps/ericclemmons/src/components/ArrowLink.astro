---
interface Props {
  href: string
  class?: string
}

const { href, class: className } = Astro.props
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-1.5 text-sm font-medium text-amber-700 transition-colors hover:text-amber-800 dark:text-amber-400 dark:hover:text-amber-300',
    className,
  ]}
>
  <slot />
  <svg
    class="size-4"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
  </svg>
</a>
