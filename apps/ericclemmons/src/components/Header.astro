---
import Avatar from './Header/Avatar.astro'

const pathname = Astro.url.pathname
---

<header class="px-6 sm:px-8 lg:px-12 py-6">
  <div class="mx-auto max-w-2xl lg:max-w-3xl">
    <nav class="flex items-center justify-between">
      <a href="/" aria-label="Home">
        <Avatar />
      </a>
      <div class="flex items-center gap-8 text-sm text-stone-600 dark:text-stone-400">
        <a
          href="/blog"
          class:list={[
            'transition hover:text-stone-900 dark:hover:text-stone-200',
            pathname.startsWith('/blog') && 'text-stone-900 dark:text-stone-200',
          ]}
        >
          Writing
        </a>
        <a
          href="/about"
          class:list={[
            'transition hover:text-stone-900 dark:hover:text-stone-200',
            pathname === '/about' && 'text-stone-900 dark:text-stone-200',
          ]}
        >
          About
        </a>
      </div>
    </nav>
  </div>
</header>
