---
const { className, href, icon: Icon } = Astro.props
---

<li class:list={[className, 'flex']}>
  <a
    href={href}
    class="group flex text-sm font-medium text-zinc-800 transition hover:text-amber-700 dark:hover:text-amber-400 dark:text-zinc-200 dark:hover:text-amber-700 dark:hover:text-amber-400"
  >
    <Icon
      className="group-hover:fill-amber-700 dark:group-hover:fill-amber-400 fill-zinc-500 h-6 w-6 flex-none transition"
    />
    <span class="ml-4">
      <slot />
    </span>
  </a>
</li>
