---
import Prose from '@/components/Prose.astro'
import Layout from '@/layouts/Spotlight.astro'
import { formatDate } from '@/lib/formatDate'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'blog'>
}

const { props } = Astro
const { post } = props
---

<Layout title={post.data.title} description={post.data.summary}>
  <div class="px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-2xl lg:max-w-3xl">
      <div class="mt-12">
        <a
          href="/blog"
          class="text-sm text-stone-500 dark:text-stone-400 hover:text-stone-700 dark:hover:text-stone-300 transition"
        >
          &larr; Writing
        </a>
      </div>

      <article class="mt-12">
        <header>
          <div class="flex items-center gap-2 text-sm text-stone-400 dark:text-stone-500">
            <time datetime={formatDate(post.data.date)}>
              {formatDate(post.data.date)}
            </time>
            <span>&middot;</span>
            <span class="text-red-700 dark:text-red-400">Eric Clemmons</span>
          </div>
          <h1 class="mt-4 font-serif text-3xl sm:text-4xl md:text-5xl font-normal tracking-tight text-stone-900 dark:text-stone-100 leading-tight">
            {post.data.title}
          </h1>
          {post.data.summary && (
            <p class="mt-6 text-lg italic text-stone-500 dark:text-stone-400">
              {post.data.summary}
            </p>
          )}
        </header>

        <div class="border-t border-stone-200 dark:border-stone-800 mt-8 mb-12"></div>

        <Prose className="mt-8">
          <slot />
        </Prose>
      </article>
    </div>
  </div>
</Layout>
