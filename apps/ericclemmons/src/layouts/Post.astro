---
import Container from '@/components/Container.astro'
import Prose from '@/components/Prose.astro'
import Layout from '@/layouts/Spotlight.astro'
import { formatDate } from '@/lib/formatDate'
import { getPosts } from '@/lib/getPosts'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'blog'>
  headings?: { depth: number; slug: string; text: string }[]
}

const { post, headings = [] } = Astro.props
const posts = await getPosts()
const index = posts.findIndex(({ id }) => id === post.id)
const nextPost = posts[index - 1]
const previousPost = posts[index + 1]
const tocHeadings = headings.filter((h) => h.depth === 2)
---

<Layout title={post.data.title} description={post.data.summary}>
  <style is:global>
    .prose-amber {
      --tw-prose-links: #b45309;
      --tw-prose-links-hover: #92400e;
      --tw-prose-underline: rgb(180 83 9 / 0.2);
      --tw-prose-underline-hover: #b45309;
      --tw-prose-invert-links: #fbbf24;
      --tw-prose-invert-links-hover: #fbbf24;
      --tw-prose-invert-underline: rgb(251 191 36 / 0.3);
      --tw-prose-invert-underline-hover: #fbbf24;
    }
    .prose-amber :is(h2, h3, h4, h5, h6) {
      color: var(--tw-prose-headings);
    }
    .prose-amber :is(h2, h3, h4, h5, h6) a {
      color: inherit;
      text-decoration: none;
    }
  </style>

  <Container className="mt-16 sm:mt-32">
    <div class="mx-auto max-w-2xl font-satoshi">
      <a
        href="/"
        class="group inline-flex items-center gap-2 text-sm text-zinc-400 transition-colors hover:text-amber-700 dark:text-zinc-500 dark:hover:text-amber-400"
      >
        <svg
          class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
        </svg>
        All posts
      </a>

      <article class="mt-10">
        <header>
          <time
            datetime={formatDate(post.data.date)}
            class="font-ibm-plex text-xs tabular-nums text-zinc-400 dark:text-zinc-600"
          >
            {formatDate(post.data.date)}
          </time>
          <h1
            class="mt-2 font-lora text-4xl tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl"
          >
            {post.data.title}
          </h1>
        </header>

        {
          tocHeadings.length >= 3 && (
            <nav class="mt-8 border-l-2 border-amber-300/60 py-1 pl-5 dark:border-amber-700/30">
              <h2 class="mb-3 text-sm font-medium text-zinc-500 dark:text-zinc-400">
                Contents
              </h2>
              <ol class="space-y-1.5" role="list">
                {tocHeadings.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="text-sm text-zinc-600 transition-colors hover:text-amber-700 dark:text-zinc-400 dark:hover:text-amber-400"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }

        <Prose
          className="prose-amber mt-10 prose-lg [&_h2]:font-lora [&_h3]:font-lora [&_h4]:font-lora"
        >
          <slot />
        </Prose>
      </article>

      <nav
        class="mt-16 flex items-start justify-between gap-8 border-t border-zinc-100 pt-8 dark:border-zinc-800/80"
      >
        {
          previousPost ? (
            <a
              href={`/blog/${previousPost.slug}`}
              class="group flex max-w-[45%] flex-col"
            >
              <span class="text-xs text-zinc-400 dark:text-zinc-500">
                Older
              </span>
              <span class="mt-0.5 text-sm font-medium text-zinc-700 transition-colors group-hover:text-amber-700 dark:text-zinc-300 dark:group-hover:text-amber-400">
                {previousPost.data.title}
              </span>
            </a>
          ) : (
            <div />
          )
        }
        {
          nextPost ? (
            <a
              href={`/blog/${nextPost.slug}`}
              class="group flex max-w-[45%] flex-col items-end text-right"
            >
              <span class="text-xs text-zinc-400 dark:text-zinc-500">
                Newer
              </span>
              <span class="mt-0.5 text-sm font-medium text-zinc-700 transition-colors group-hover:text-amber-700 dark:text-zinc-300 dark:group-hover:text-amber-400">
                {nextPost.data.title}
              </span>
            </a>
          ) : (
            <div />
          )
        }
      </nav>
    </div>
  </Container>
</Layout>
